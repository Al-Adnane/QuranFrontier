    {
      "text_id": "native_precepts",
      "text_name_en": "Native American Precepts",
      "date": "~10000 BCE-present",
      "precepts": [
        {
          "precept_id": "nat_c1",
          "text": "Respect the Earth",
          "translation_en": "The Earth is our mother, treat her well"
        },
        {
          "precept_id": "nat_c2",
          "text": "Honor the Ancestors",
          "translation_en": "Those who came before guide us"
        },
        {
          "precept_id": "nat_c3",
          "text": "Live in Balance",
          "translation_en": "Walk the middle path"
        },
        {
          "precept_id": "nat_c4",
          "text": "Share with All",
          "translation_en": "What you have, share with your people"
        },
        {
          "precept_id": "nat_c5",
          "text": "Listen to Nature",
          "translation_en": "The land speaks, listen well"
        },
        {
          "precept_id": "nat_c6",
          "text": "Honor the Seven Directions",
          "translation_en": "North, South, East, West, Above, Below, Within"
        }
      ]
    },
