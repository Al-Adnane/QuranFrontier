  "texts": [
    {
      "text_id": "popol_vuh",
      "text_name_maya": "Popol Vuh",
      "text_name_en": "Popol Vuh (Book of Counsel)",
      "date": "~1550 CE (oral tradition ~2000 BCE)",
      "sections": [
        {
          "section_id": "pv_1",
          "name": "Creation of the World",
          "kiche": "Are' uxe' ri wuj, are' ri uchi' ri wuj",
          "transliteration": "Are' uxe' ri wuj, are' ri uchi' ri wuj",
          "translation_en": "This is the beginning of the book, this is the root of the book"
        },
        {
          "section_id": "pv_2",
          "name": "The Gods Speak",
          "kiche": "Xaq xwi' kaqik'ij ri qak'aslemal",
          "transliteration": "Xaq xwi' kaqik'ij ri qak'aslemal",
          "translation_en": "Let us glorify our life"
        },
        {
          "section_id": "pv_3",
          "name": "First Attempt - Animals",
          "kiche": "Xkib'an ri juyub', xkib'an ri cho'oy",
          "transliteration": "Xkib'an ri juyub', xkib'an ri cho'oy",
          "translation_en": "They made the mountains, they made the valleys"
        },
        {
          "section_id": "pv_4",
          "name": "Second Attempt - Mud",
          "kiche": "Xkib'an ri winaq ri xab'aq",
          "transliteration": "Xkib'an ri winaq ri xab'aq",
          "translation_en": "They made the people of mud"
        },
        {
          "section_id": "pv_5",
          "name": "Third Attempt - Wood",
          "kiche": "Xkib'an ri winaq ri che'",
          "transliteration": "Xkib'an ri winaq ri che'",
          "translation_en": "They made the people of wood"
        },
        {
          "section_id": "pv_6",
          "name": "Fourth Attempt - Maize",
          "kiche": "Xkib'an ri winaq ri imox",
          "transliteration": "Xkib'an ri winaq ri imox",
          "translation_en": "They made the people of maize"
        },
        {
          "section_id": "pv_7",
          "name": "The Hero Twins",
          "kiche": "Junajpu, Xbalanqe, are' ri k'ak'a winaq",
          "transliteration": "Junajpu, Xbalanqe, are' ri k'ak'a winaq",
          "translation_en": "Hunahpu, Xbalanque, these are the new people"
        },
        {
          "section_id": "pv_8",
          "name": "The Ball Game",
          "kiche": "Xkib'an ri pitz, xkib'an ri k'ak'",
          "transliteration": "Xkib'an ri pitz, xkib'an ri k'ak'",
          "translation_en": "They made the ball game, they made the fire"
        }
      ]
    },
    {
      "text_id": "maya_prayers",
      "text_name_maya": "K'ak' Tzij",
      "text_name_en": "Maya Prayers",
      "date": "~500 BCE-1500 CE",
      "prayers": [
        {
          "prayer_id": "maya_p1",
          "name": "Prayer to Itzamna",
          "kiche": "Itzamna, ajaw k'uh, kaqik'ij",
          "transliteration": "Itzamna, ajaw k'uh, kaqik'ij",
          "translation_en": "Itzamna, lord god, we glorify"
        },
        {
          "prayer_id": "maya_p2",
          "name": "Prayer to Kukulkan",
          "kiche": "Kukulkan, kan k'uh, kaqik'ij",
          "transliteration": "Kukulkan, kan k'uh, kaqik'ij",
          "translation_en": "Kukulkan, feathered serpent god, we glorify"
        },
        {
          "prayer_id": "maya_p3",
          "name": "Prayer for Rain",
          "kiche": "Ha', ha', ha', kaqik'ij",
          "transliteration": "Ha', ha', ha', kaqik'ij",
          "translation_en": "Water, water, water, we glorify"
        },
        {
          "prayer_id": "maya_p4",
          "name": "Prayer for Maize",
          "kiche": "Imox, imox, imox, kaqik'ij",
          "transliteration": "Imox, imox, imox, kaqik'ij",
          "translation_en": "Maize, maize, maize, we glorify"
        }
      ]
    },
