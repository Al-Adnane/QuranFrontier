  "texts": [
    {
      "text_id": "havamal",
      "text_name_on": "Hávamál",
      "text_name_en": "Sayings of the High One (Odin)",
      "date": "~800-1000 CE",
      "stanzas": [
        {
          "stanza_id": "hav_1",
          "old_norse": "Gáttir allar, áðr gangi fram, um skoðask skyli, um skygnask skyli",
          "translation_en": "At all doorways, before one goes forward, one should look, one should spy"
        },
        {
          "stanza_id": "hav_9",
          "old_norse": "Sá er einn, hvat skal hann lifa?",
          "translation_en": "He who is alone, how shall he live?"
        },
        {
          "stanza_id": "hav_77",
          "old_norse": "Deyr fé, deyja frændr, deyr sjálfr it sama; en orðstírr deyr aldregi, hveim er sér góðan getr",
          "translation_en": "Cattle die, kinsmen die, one dies oneself; but fame never dies, for him who gets a good one"
        },
        {
          "stanza_id": "hav_138",
          "old_norse": "Veit ek at ek hekk vindga meiði á, nætr allar níu, geiri undaðr ok gefinn Óðni, sjálfr sjalfum mér",
          "translation_en": "I know that I hung on a windy tree, nine long nights, wounded with a spear and given to Odin, myself to myself"
        }
      ]
    },
    {
      "text_id": "voluspa",
      "text_name_on": "Völuspá",
      "text_name_en": "Prophecy of the Seeress",
      "date": "~900-1000 CE",
      "stanzas": [
        {
          "stanza_id": "vol_1",
          "old_norse": "Hliðs bið ek allar helgar kindir, meiri ok minni mögu Heimdallar",
          "translation_en": "Silence I ask of all holy races, great and small, sons of Heimdall"
        },
        {
          "stanza_id": "vol_3",
          "old_norse": "Ár var alda, þat er ekki var, varka sandr né sær né svalar unnir",
          "translation_en": "It was early in ages, when nothing was, no sand nor sea nor cool waves"
        },
        {
          "stanza_id": "vol_9",
          "old_norse": "Ask veit ek standa, heitir Yggdrasill, hár baðmr, ausinn hvíta auri",
          "translation_en": "An ash I know stands, Yggdrasil it is called, a high tree, sprinkled with white clay"
        },
        {
          "stanza_id": "vol_57",
          "old_norse": "Þá kømr inn ríki at regindómi, ofan ofanleitr allvaldr",
          "translation_en": "Then comes the mighty one to the great judgment, from above, the all-ruler"
        }
      ]
    },
