        {
          "inscription_id": "ogh_2",
          "ogham": "᚛ᚔᚊᚊᚔᚅᚐᚃᚐᚂᚂᚐᚄᚋᚐᚊᚊᚔᚏᚐᚔᚊᚔᚊᚔᚅᚐ᚜",
          "transliteration": "IQIQINAVALLASAMACCIQIQIQINA",
          "translation_en": "Of Icicina, daughter of Vallas"
        },
        {
          "inscription_id": "ogh_3",
          "ogham": "᚛ᚋᚐᚊᚊᚔᚏᚐᚔᚊᚔᚊᚔᚅᚐᚃᚐᚂᚂᚐᚄᚋᚐᚊᚊᚔᚏᚐᚔᚊᚔᚊᚔᚅᚐ᚜",
          "transliteration": "MACCIQIQIQINAVALLASAMACCIQIQIQINA",
          "translation_en": "Of Macci, son of Icicina"
        }
      ]
    },
    {
      "text_id": "irish_mythology",
