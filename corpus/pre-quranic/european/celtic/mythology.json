      "text_name_en": "Irish Mythology",
      "date": "~800-1200 CE (oral tradition older)",
      "passages": [
        {
          "passage_id": "irish_1",
          "name": "The Dagda's Cauldron",
          "old_irish": "Coire ansic, in Dagda",
          "translation_en": "The Undry Cauldron, of the Dagda"
        },
        {
          "passage_id": "irish_2",
          "name": "The Well of Wisdom",
          "old_irish": "Tobar Segais, na n-ecna",
          "translation_en": "The Well of Segais, of wisdom"
        },
        {
          "passage_id": "irish_3",
          "name": "The Salmon of Knowledge",
          "old_irish": "Bradán feasa, ón tobar",
          "translation_en": "The Salmon of Knowledge, from the well"
        },
        {
          "passage_id": "irish_4",
          "name": "The Morrigan",
          "old_irish": "An Mhorrígan, banríon na cath",
          "translation_en": "The Morrigan, queen of battles"
        },
        {
          "passage_id": "irish_5",
          "name": "Lugh of the Long Arm",
          "old_irish": "Lugh Lámhfhada, mac Ethlenn",
          "translation_en": "Lugh of the Long Arm, son of Ethliu"
        },
        {
          "passage_id": "irish_6",
          "name": "Brigid the Poet",
          "old_irish": "Brigid, banfhile, banleighis",
          "translation_en": "Brigid, woman poet, woman healer"
        }
      ]
    },
    {
      "text_id": "celtic_precepts",
      "text_name_ga": "Bunrialta Ceilteach",
      "text_name_en": "Celtic Precepts",
      "date": "~500 BCE-800 CE",
      "precepts": [
        {
          "precept_id": "celt_1",
          "old_irish": "Fir flatha, fir fer",
          "translation_en": "The truth of rulers, the truth of men"
        },
        {
          "precept_id": "celt_2",
          "old_irish": "Díles do charait",
          "translation_en": "Be loyal to your friend"
        },
        {
          "precept_id": "celt_3",
          "old_irish": "Géill do cheile",
          "translation_en": "Honor your spouse"
        },
        {
          "precept_id": "celt_4",
          "old_irish": "Uasal do thír",
          "translation_en": "Be noble to your land"
        },
        {
          "precept_id": "celt_5",
          "old_irish": "Cairde do chine",
          "translation_en": "Be kind to your kin"
        },
        {
          "precept_id": "celt_6",
          "old_irish": "Onóir do dhia",
          "translation_en": "Honor your god"
        },
        {
          "precept_id": "celt_7",
          "old_irish": "Grá do gach ní",
          "translation_en": "Love all things"
        }
      ]
    },
    {
