    {
      "text_id": "ashem_vohu",
      "text_name_av": "𐬀𐬴𐬆𐬨 𐬬𐬊𐬵𐬏",
      "text_name_en": "The Ashem Vohu Prayer",
      "date": "~1000-800 BCE",
      "accuracy": "UNVERIFIED - Check against critical editions",
      "verses": [
        {
          "verse_id": "ashem_1",
          "text_av": "𐬀𐬴𐬆𐬨 𐬬𐬊𐬵𐬏 𐬬𐬀𐬵𐬌𐬯𐬙𐬆𐬨 𐬀𐬯𐬙𐬌",
          "transliteration": "ašem vohū vahistem astī",
          "translation_en": "Righteousness is the best good",
          "note": "Verify Unicode against manuscript evidence"
        },
        {
          "verse_id": "ashem_2",
          "text_av": "𐬎𐬱𐬁 𐬀𐬯𐬙𐬌",
          "transliteration": "ušā astī",
          "translation_en": "It is happiness",
          "note": "Verify Unicode against manuscript evidence"
        },
        {
          "verse_id": "ashem_3",
          "text_av": "𐬀𐬴𐬆𐬨𐬁𐬌 𐬘𐬌𐬙 𐬀𐬴𐬁𐬌 𐬬𐬀𐬵𐬌𐬴𐬙𐬁𐬌 𐬀𐬯𐬙𐬌",
          "transliteration": "ašemāi cit̰ aṣ̌āi vahištāi astī",
          "translation_en": "Happiness is to him who is righteous for the sake of the best righteousness",
          "note": "Verify Unicode against manuscript evidence"
        }
      ]
    }
