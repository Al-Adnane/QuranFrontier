# Database Configuration
DB_USER=quran_user
DB_PASSWORD=change-me-to-strong-password-in-production
DB_NAME=quran_db

# Neo4j Configuration
NEO4J_PASSWORD=change-me-to-neo4j-password-in-production

# API Configuration
API_SECRET_KEY=change-me-to-real-secret-key-min-32-chars-prod
JWT_SECRET=change-me-to-real-jwt-secret-min-32-chars-prod

# Grafana Configuration
GRAFANA_PASSWORD=change-me-to-grafana-admin-password

# Optional: Third-party Service Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Kubernetes Configuration
KUBECONFIG=/path/to/kubeconfig
NAMESPACE=quran-system
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=
DOCKER_PASSWORD=
