        overall = (timing_score + linguistic_score + emotional_score + profile_score) / 4\
        \
        return \{\
            'is_synthetic': overall > 0.5,\
            'confidence': overall,\
            'scores': \{\
                'timing': timing_score,\
                'linguistic': linguistic_score,\
                'emotional': emotional_score,\
                'profile': profile_score\
            \},\
            'indicators': self._get_indicators(overall)\
        \}\
