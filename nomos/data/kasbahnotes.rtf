\f8\fs24 \cf0 /**\
 * Validation suite for Consciousness Provenance Engine (KCPE)\
 * \
 * Tests against:\
 * - Human-written content (known samples)\
 * - AI-generated content (GPT-4, Claude, etc.)\
 * - Mixed content (human-edited AI)\
 */\
\
const fs = require('fs');\
const path = require('path');\
const \{ ConsciousnessProvenanceEngine \} = require('../src');\
\
class ConsciousnessValidator \{\
  constructor() \{\
    this.engine = new ConsciousnessProvenanceEngine();\
    this.results = \{\
      human: [],\
      ai: [],\
      mixed: []\
    \};\
  \}\
\
  /**\
   * Load validation dataset\
   */\
  loadDataset(datasetPath) \{\
    const dataset = JSON.parse(fs.readFileSync(datasetPath, 'utf8'));\
    \
    for (const sample of dataset.samples) \{\
      const result = this.engine.analyze(sample.text);\
      result.trueLabel = sample.label; // 'human' or 'ai'\
      \
      this.results[sample.category].push(result);\
    \}\
    \
    return this.calculateMetrics();\
  \}\
\
  /**\
   * Calculate validation metrics\
   */\
  calculateMetrics() \{\
    const metrics = \{\
      accuracy: 0,\
      precision: 0,\
      recall: 0,\
      f1: 0,\
      auc: 0\
    \};\
\
    // Calculate accuracy\
    let correct = 0;\
    let total = 0;\
    \
    for (const result of this.results.human) \{\
      total\ul ;\
      if (result.consciousnessScore > 0.5) correct\ulnone ; // Human should score high\
    \}\
    \
    for (const result of this.results.ai) \{\
      total\ul ;\
      if (result.consciousnessScore <= 0.5) correct\ulnone ; // AI should score low\
    \}\
    \
    metrics.accuracy = correct / total;\
    \
    // Calculate precision, recall, F1\
    const tp = this.results.human.filter(r => r.consciousnessScore > 0.5).length;\
    const fp = this.results.ai.filter(r => r.consciousnessScore > 0.5).length;\
    const fn = this.results.human.filter(r => r.consciousnessScore <= 0.5).length;\
    \
    metrics.precision = tp / (tp + fp);\
    metrics.recall = tp / (tp + fn);\
    metrics.f1 = 2 * (metrics.precision * metrics.recall) / (metrics.precision + metrics.recall);\
    \
    return \{\
      metrics,\
      results: this.results,\
      sampleCount: total\
    \};\
  \}\
\
  /**\
   * Generate validation report\
   */\
  generateReport() \{\
    const validation = this.calculateMetrics();\
    \
    const report = \{\
      timestamp: new Date().toISOString(),\
      validator: 'ConsciousnessProvenanceEngine',\
      version: '3.0.0',\
      metrics: validation.metrics,\
      sampleCount: validation.sampleCount,\
      breakdown: \{\
        human: \{\
          count: this.results.human.length,\
          avgScore: this.results.human.reduce((sum, r) => sum + r.consciousnessScore, 0) / this.results.human.length\
        \},\
        ai: \{\
          count: this.results.ai.length,\
          avgScore: this.results.ai.reduce((sum, r) => sum + r.consciousnessScore, 0) / this.results.ai.length\
        \}\
      \},\
      conclusion: validation.metrics.f1 > 0.8 ? 'VALIDATED' : 'NEEDS_IMPROVEMENT'\
    \};\
    \
    // Save report\
    fs.writeFileSync(\
      path.join(__dirname, 'consciousness-validation-report.json'),\
      JSON.stringify(report, null, 2)\
    );\
    \
    return report;\
  \}\
\}\
\
