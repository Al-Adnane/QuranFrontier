\f8\fs24 \cf0 class DifferentialPrivacy:\
    """\
    Implements differential privacy for data analysis.\
    \
    Uses Laplace noise mechanism:\
    noisy_value = true_value + Laplace(\uc0\u916 f / \u949 )\
    \
    Where:\
    - \uc0\u916 f = sensitivity (max change from single record)\
    - \uc0\u949  = privacy budget (lower = more privacy)\
    """\
    \
    def __init__(self, epsilon: float = 1.0, delta: float = 0.0):\
        self.epsilon = epsilon  # Privacy budget\
        self.delta = delta      # Probability of failure\
    \
    def add_laplace_noise(self, value: float, sensitivity: float = 1.0) -> float:\
        """Adds Laplace noise to value."""\
        scale = sensitivity / self.epsilon\
        noise = np.random.laplace(0, scale)\
        return value + noise\
    \
    def privatize_query(self, query_result: float, sensitivity: float = 1.0) -> dict:\
        """Returns privatized query result with metadata."""\
        noisy_result = self.add_laplace_noise(query_result, sensitivity)\
        return \{\
            'original': query_result,\
            'noisy': noisy_result,\
            'epsilon': self.epsilon,\
            'sensitivity': sensitivity,\
            'privacy_guarantee': f'(\uc0\u949 =\{self.epsilon\}, \u948 =\{self.delta\})-differential privacy'\
        \}\
